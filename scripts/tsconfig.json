{
	"compilerOptions": {
		"target": "ES2022",
		"types": ["node"],
		"module": "commonjs",
		"lib": ["ES2022"],
		"outDir": "./dist",
		"rootDir": ".",
		"strict": true,
		"noImplicitAny": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"sourceMap": true
	},
	"include": ["./**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
